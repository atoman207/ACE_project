# Copy to .env.local and replace placeholders (do not commit .env.local).
# Server reads jobs from Supabase table `public.jobs` — no mock fallback.
#
# Expected columns (snake_case or camelCase where noted):
#   id, company, company_kind, position, summary, location, salary, salary_min, salary_max,
#   employment_type, remote, tags (text[] or json), status, posted_at (required for ORDER BY),
#   description, requirements (text[]), preferred (text[]), company_overview, work_hours,
#   benefits (text[]), holidays, selection_process (text[]), ideal_candidate, is_confidential (bool)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
# Optional: set when your jobs table name is not `jobs`.
# SUPABASE_JOBS_TABLE=job_postings

# Session signing secret for auth cookies (any random string).
# Falls back to SUPABASE_SERVICE_ROLE_KEY if unset — set explicitly in production.
SESSION_SECRET=change-me

# Public site origin used in emails and sitemap.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin notification email when a candidate applies.
ADMIN_NOTIFICATION_EMAIL=Admin@gmail.com

# Mail delivery — optional. If RESEND_API_KEY is set, email sends via Resend.
# Without it, mail calls log to stdout (useful for development).
RESEND_API_KEY=
MAIL_FROM=ACE Career <noreply@acecareer.jp>

# Google Analytics 4 measurement ID (e.g. G-XXXXXXX). Optional.
NEXT_PUBLIC_GA_ID=

# Google Search Console HTML meta verification token. Optional.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
